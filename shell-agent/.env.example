# =============================================================================
# shell-agent — environment configuration
# =============================================================================
# Copy this file to .env and fill in the required values.
# Lines starting with # are comments. Uncomment a line to activate it.
#
# DEFAULT LLM: OpenAI (gpt-4o-mini) — set OPENAI_API_KEY and nothing else.
# To switch provider: uncomment LLM_PROVIDER + LLM_MODEL + LLM_API_KEY below.
# =============================================================================


# =============================================================================
# REQUIRED — must be set before the agent does anything useful
# =============================================================================

# Sui wallet keypair (bech32, suiprivkey1…). Used by `run` and `post-ioi`.
# Generate: sui client new-address ed25519
# Export:   sui keytool export --key-identity <ADDRESS>
# Not used by `demo` (demo uses DEMO_BUYER_KEY / DEMO_SELLER_KEY below).
AGENT_PRIVATE_KEY=

# OpenAI API key — default LLM provider when LLM_PROVIDER is not set.
# Get one at https://platform.openai.com/api-keys
# If you want a different provider (Anthropic, Google, Ollama…) leave this
# blank and use the LLM_* block below instead.
OPENAI_API_KEY=

# Free-text policy — the LLM uses this for TWO decisions per tick:
#   (1) IOI posting: every TTL window, the LLM calls tools (ref price, balance,
#       risk caps, recent fills) and picks IOI terms (side, size range, price
#       range, ttl) that satisfy this policy. It may also skip posting.
#   (2) Match acceptance: when a proposal arrives, the LLM checks the same
#       policy to decide accept / reject / wait.
#
# Prices are 1e6-scaled USDC (1.00 USDC = 1_000_000).
# Sizes  are 1e9-scaled SUI  (1 SUI    = 1_000_000_000).
#
# Example — directional accumulator:
#   Accumulate 1-3 SUI when DeepBook mid < 1.0 USDC. Max position 10 SUI.
#   Scale down size as position grows. Skip if spread > 2%. Reject any match
#   above declared price range.
#
# Example — passive market maker:
#   Post buy IOIs at 5-10 bps below mid, sell IOIs at 5-10 bps above. Refresh
#   every 30 minutes. Accept any match within ±0.5% of current mid. Use
#   check_risk_cap before accepting; reject if within_cap=false.
AGENT_POLICY=Accept matches within declared range. Call check_risk_cap first. Reject if within_cap=false or size > 1 SUI.


# =============================================================================
# REQUIRED FOR `demo` MODE  (node dist/index.js demo)
# =============================================================================
# Two funded testnet wallets.
# Each needs ~2 SUI for gas. Buyer also needs ≥ 0.22 USDC for collateral.
# USDC coin type: 0xa1ec7fc00a6f40db9693ad1415d0c193ad3906494428cf252621037bd7117e29::usdc::USDC
# Faucet: https://faucet.testnet.sui.io  (SUI only — get USDC from testnet USDC faucet)
DEMO_BUYER_KEY=
DEMO_SELLER_KEY=


# =============================================================================
# OPTIONAL — LLM provider (defaults to OpenAI + gpt-4o-mini via OPENAI_API_KEY)
# =============================================================================
# Uncomment the block for your chosen provider.
# LLM_API_KEY takes precedence over OPENAI_API_KEY when set.
# LLM_PROVIDER must be one of: openai | anthropic | google | openai-compatible

# ── OpenAI (explicit) ──────────────────────────────────────────────────────
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini        # or gpt-4o, gpt-4-turbo, o3-mini, etc.
# LLM_API_KEY=sk-...

# ── Anthropic Claude ──────────────────────────────────────────────────────
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-haiku-4-5-20251001   # fastest/cheapest
# LLM_MODEL=claude-sonnet-4-6           # best quality
# LLM_API_KEY=sk-ant-...

# ── Google Gemini ─────────────────────────────────────────────────────────
# LLM_PROVIDER=google
# LLM_MODEL=gemini-2.0-flash   # fast + tool-capable
# LLM_MODEL=gemini-2.5-pro     # best quality
# LLM_API_KEY=AIza...

# ── OpenAI-compatible (Ollama, vLLM, OpenRouter, Together, Groq, etc.) ───
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=http://localhost:11434/v1   # Ollama local
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.1-8b-instant          # any model the endpoint accepts
# LLM_API_KEY=                             # some endpoints need no key

# Legacy model override for the default OpenAI path (ignored when LLM_MODEL set)
OPENAI_MODEL=gpt-4o-mini


# =============================================================================
# OPTIONAL — IOI fallback defaults for `run` mode
# =============================================================================
# In `run` mode the LLM picks IOI terms each posting window using
# AGENT_POLICY + live tools. These values are FALLBACK DEFAULTS used
# only when the LLM response is missing a field or fails to parse.
# Override AGENT_POLICY to control behaviour, not these values.
#
# Size  = raw u64 at 1e9 scale: 1 SUI  = 1_000_000_000
# Price = raw u64 at 1e6 scale: 1 USDC = 1_000_000
AGENT_IOI_SIDE=buy                  # buy | sell — fallback side
AGENT_IOI_ASSET=0x2::sui::SUI       # fallback asset (Move type tag)
AGENT_IOI_SIZE_LO=100000000         # 0.1 SUI fallback min
AGENT_IOI_SIZE_HI=200000000         # 0.2 SUI fallback max
AGENT_IOI_PRICE_LO=900000           # 0.90 USDC fallback min
AGENT_IOI_PRICE_HI=1100000          # 1.10 USDC fallback max
AGENT_IOI_TTL_MIN=60                # fallback TTL minutes (LLM may override 5-1440)
AGENT_POLL_INTERVAL_SEC=15          # how often (seconds) the run loop polls for proposals


# =============================================================================
# OPTIONAL — Risk caps (enables check_risk_cap tool enforcement)
# =============================================================================
# When set > 0, the check_risk_cap tool will return within_cap=false if the
# projected position or daily volume would exceed these limits.
# Include "Call check_risk_cap" in AGENT_POLICY to gate LLM accepts on these.
# Required for Step 1a of the demo. Leave commented to disable (no cap).
# RISK_MAX_POSITION_SUI=0.3          # max net open position across all fills + orders
# RISK_DAILY_VOLUME_SUI=20.0         # max total filled SUI per UTC day


# =============================================================================
# OPTIONAL — Webhook (enables notify_webhook tool)
# =============================================================================
# If set, the notify_webhook tool will POST { event, data, ts } to this URL.
# Useful for Slack/Discord alerts, monitoring dashboards, or custom automation.
# Use https://webhook.site to get a free test URL that shows incoming payloads.
# WEBHOOK_URL=https://webhook.site/your-unique-id


# =============================================================================
# OPTIONAL — RWA / custom trading pair
# =============================================================================
# Override to trade a non-SUI base asset (e.g. testnet TBILL mock).
# AGENT_BASE_COIN_TYPE defaults to SUI; AGENT_BASE_DECIMALS defaults to 9.
#
# Example — TBILL/USDC on testnet:
# AGENT_BASE_COIN_TYPE=0x70d3c2d589fcbe55eff1be5eebbe5cf50f051c0a274e1e34cd383ecd8a107719::tbill::TBILL
# AGENT_BASE_DECIMALS=6
# AGENT_IOI_ASSET=0x70d3c2d589fcbe55eff1be5eebbe5cf50f051c0a274e1e34cd383ecd8a107719::tbill::TBILL
# AGENT_IOI_SIZE_LO=1000000        # 1 TBILL  (6 decimals)
# AGENT_IOI_SIZE_HI=1000000000     # 1000 TBILL
# AGENT_IOI_PRICE_LO=1000000       # $1.00 USDC (1e6 scale)
# AGENT_IOI_PRICE_HI=1000000       # $1.00 USDC (fixed NAV)
#
# AGENT_BASE_COIN_TYPE=0x2::sui::SUI
# AGENT_BASE_DECIMALS=9


# =============================================================================
# OPTIONAL — Sui + Walrus endpoints (defaults hit public testnet nodes)
# =============================================================================
# Override these if you run a private RPC node or Walrus node.
# SUI_RPC_URL=https://fullnode.testnet.sui.io
# WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space
# WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space

# Quote coin type — testnet USDC. Change only if using a different quote token.
# QUOTE_COIN_TYPE=0xa1ec7fc00a6f40db9693ad1415d0c193ad3906494428cf252621037bd7117e29::usdc::USDC

# DeepBook indexer for the get_ref_price tool.
# DEEPBOOK_INDEXER_URL=https://deepbook-indexer.testnet.mystenlabs.com
# DEEPBOOK_POOL_KEY=SUI_DBUSDC


# =============================================================================
# OPTIONAL — Shell on-chain artifact IDs (pin to a specific deployment)
# =============================================================================
# Leave ALL of these commented to use the defaults in src/config.ts, which
# track the latest testnet republish automatically.
# Only uncomment to pin against a specific old deployment for debugging.
# SHELL_PACKAGE_ID=0x23d1e8b5b562bff7e30c69a20d2d0075074e3170898aa8bf9596de635764e36e
# SHELL_PACKAGE_ID_LATEST=0x23d1e8b5b562bff7e30c69a20d2d0075074e3170898aa8bf9596de635764e36e
# SHELL_PACKAGE_ID_IOI_TYPES=0x23d1e8b5b562bff7e30c69a20d2d0075074e3170898aa8bf9596de635764e36e
# ENCLAVE_ID=0x92101a18928039d3da63ea9e8c1fa300bdce3edb473c69ce686d2a413bd1848a
# ENCLAVE_CONFIG_ID=0x9ddc4bd22c4a84a7f02ac86d1a64530ecc768cb47df48dffd8d33803a096a504
