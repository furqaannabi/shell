# Agent's Sui keypair (suiprivkey1... bech32). Owns SUI for gas + collateral.
AGENT_PRIVATE_KEY=

# OpenAI API key for LLM reasoning over match proposals.
OPENAI_API_KEY=

# Sui testnet RPC.
SUI_RPC_URL=https://fullnode.testnet.sui.io

# Walrus testnet endpoints (defaults are public; override for private node).
WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space
WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space

# Shell on-chain artifacts (testnet). Mirrors ts-sdk/deployments/testnet.json.
SHELL_PACKAGE_ID=0x6a9fb5d245856d9c81da6952b431dceebf870820766df0bee8a6339cb06a56fd
ENCLAVE_ID=0xe342ee55ef3b0107669318d9d9b3ced045afe5424e7dec265ee39e28d25cf948
ENCLAVE_CONFIG_ID=0xd33555df99c5065a610e479ad39f711ba0219da1f04276b3c2be71101f8f7bb8

# Optional: free-text policy for the LLM to reason against (one line).
AGENT_POLICY=Accept matches priced within 2% of recent VWAP; size <= 100 SUI per match.

# Optional: model. Defaults to gpt-4o-mini for cheap polling.
OPENAI_MODEL=gpt-4o-mini
