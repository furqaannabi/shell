# Agent's Sui keypair (suiprivkey1... bech32). Owns SUI for gas + collateral.
# Required by `run` and `post-ioi` modes. Not used by `demo`.
AGENT_PRIVATE_KEY=

# ── LLM provider (v2 — pluggable) ──────────────────────────────────────
# Pick one provider. Defaults below are backward-compat with pre-v2 env files
# (only OPENAI_API_KEY set → openai + gpt-4o-mini).
#   openai             — official OpenAI API
#   anthropic          — Claude (wired in step 6)
#   google             — Gemini  (wired in step 6)
#   openai-compatible  — any OpenAI-shaped endpoint (Ollama, vLLM, OpenRouter, Together…)
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=
# LLM_BASE_URL=                       # set only for openai-compatible (e.g. https://openrouter.ai/api/v1)

# Legacy fallback — used when LLM_* keys are unset.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Sui testnet RPC.
SUI_RPC_URL=https://fullnode.testnet.sui.io

# Walrus testnet endpoints (defaults are public; override for private node).
WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space
WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space

# Shell on-chain artifacts (testnet) — fresh-publish 2026-05-24.
# Mirrors ts-sdk/deployments/testnet.json. Leave these COMMENTED to use the
# defaults in src/config.ts — those track the latest republish automatically.
# Only set them here to pin against a specific old deployment for debugging.
# SHELL_PACKAGE_ID=0x23d1e8b5b562bff7e30c69a20d2d0075074e3170898aa8bf9596de635764e36e
# SHELL_PACKAGE_ID_LATEST=0x23d1e8b5b562bff7e30c69a20d2d0075074e3170898aa8bf9596de635764e36e
# SHELL_PACKAGE_ID_IOI_TYPES=0x23d1e8b5b562bff7e30c69a20d2d0075074e3170898aa8bf9596de635764e36e
# ENCLAVE_ID=0x92101a18928039d3da63ea9e8c1fa300bdce3edb473c69ce686d2a413bd1848a
# ENCLAVE_CONFIG_ID=0x9ddc4bd22c4a84a7f02ac86d1a64530ecc768cb47df48dffd8d33803a096a504

# Free-text policy for the LLM to gate every match proposal against.
# Examples:
#   "Only accept buys at price ≤ 1.00 USDC. Reject size > 0.5 SUI."
#   "Sell aggressively above 1.05 USDC, reject below."
AGENT_POLICY=Accept matches within declared range. Reject if size > 1 SUI.

# ── `run` mode auto-IOI parameters ─────────────────────────────────────
# Size = raw u64 at 1e9 scale (1 SUI = 1_000_000_000).
# Price = raw u64 at 1e6 scale (1.00 USDC per SUI = 1_000_000) — matches
# the web IOI form and enclave matcher. NOT the old 1e9 DUSDC scale.
AGENT_IOI_SIDE=buy
AGENT_IOI_ASSET=0x2::sui::SUI
AGENT_IOI_SIZE_LO=100000000          # 0.1 SUI
AGENT_IOI_SIZE_HI=200000000          # 0.2 SUI
AGENT_IOI_PRICE_LO=900000            # 0.90 USDC
AGENT_IOI_PRICE_HI=1100000           # 1.10 USDC
AGENT_IOI_TTL_MIN=60

# ── Risk caps (optional — 0 disables) ─────────────────────────────────
# check_risk_cap tool uses these to gate the LLM's position/volume check.
# RISK_MAX_POSITION_SUI=5.0       # max net position in SUI across all fills + open orders
# RISK_DAILY_VOLUME_SUI=20.0      # max total filled SUI per UTC day

# ── Webhook (optional) ─────────────────────────────────────────────────
# notify_webhook tool POSTs { event, data, ts } here if set.
# WEBHOOK_URL=https://hooks.example.com/shell-agent

# ── `demo` mode (node dist/index.js demo) ──────────────────────────────
# Two funded testnet wallets — each needs ~2 SUI gas. Buyer additionally
# needs ≥ AGENT_IOI_SIZE_HI * AGENT_IOI_PRICE_HI / 1e9 in USDC
# (≈ 0.22 USDC for the defaults above). Quote coin type:
#   0xa1ec7fc00a6f40db9693ad1415d0c193ad3906494428cf252621037bd7117e29::usdc::USDC
DEMO_BUYER_KEY=
DEMO_SELLER_KEY=
