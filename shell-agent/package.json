    "@mysten/sui": "^2.16.2",
    "@shell-finance/sdk": "^0.1.4",
    "chalk": "^5.6.2",
    "dotenv": "^16.4.0",
    "openai": "^4.77.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
